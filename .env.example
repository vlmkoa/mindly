# Copy this to .env.local and fill in your values.
#
# .env.local is read by BOTH:
#   - Next.js (frontend, BACKEND_URL for the /api proxy)
#   - docker-compose (env_file for the api service → ANTHROPIC_API_KEY)

# Anthropic key — used by the FastAPI backend for /api/chat, and by evals.
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Where the Next.js dev server proxies /api/* (FastAPI in Docker).
BACKEND_URL=http://localhost:8000

# Uncomment ONLY if the eval harness fails TLS verification on this machine
# (e.g. a proxy that intercepts HTTPS). Disables cert verification for
# evals/run.py only — the API key becomes interceptable on that connection.
# KOAN_EVAL_INSECURE_SSL=1
